# Robinhood credentials — never commit this file
RH_USERNAME=your_robinhood_email@example.com
RH_PASSWORD=your_robinhood_password

# Risk limits (optional — these are the safe defaults)
MAX_POSITION_PCT=0.10        # reject orders that would make any position > 10% of portfolio
DAILY_LOSS_LIMIT_PCT=0.02    # halt trading if portfolio drops 2% intraday

# DRY_RUN=true means orders are logged but never submitted to Robinhood
# Set to false only after you've tested and are comfortable with the agent
DRY_RUN=true
